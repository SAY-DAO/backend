BASE_URL=https://${CI_COMMIT_REF_SLUG}.api.staging.sayapp.company
dbUrl=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}/${POSTGRES_DB}
broker_url=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@${RABBITMQ_HOST}:5672/
result_backend=rpc://
redbeat_redis_url=redis://${REDIS_HOST}:6379/0
SANDBOX=true
DELIVER_TO_CHILD_DELAY=1 * 60
SECRET_KEY=${CI_COMMIT_REF_SLUG}
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300,
CACHE_REDIS_URL=redis://${REDIS_HOST}:6379/0
CACHE_REDIS_HOST=${REDIS_HOST}
CACHE_REDIS_PORT=6379
CACHE_KEY_PREFIX=fcache
